<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ site.characterName }}'s Apothecary</title>
    <meta name="description" content="{{ site.tagline }}">
    <meta property="og:title" content="{{ site.characterName }}">
    <meta property="og:description" content="{{ site.tagline }}">
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ site.url }}">
    <meta property="og:image" content="{{ site.url }}images/{{ site.ogImage }}">
    <meta name="twitter:card" content="summary_large_image">
    <link rel="canonical" href="{{ site.url }}">
    <link rel="icon" href="favicon.svg" type="image/svg+xml">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700;900&family=Cinzel:wght@500;600&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="styles/style.css">
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <div class="page" id="top">
      <nav class="site-nav" aria-label="Main navigation">
        <div class="site-nav-inner">
          <a class="site-nav-logo" href="#top">{{ site.characterName }}</a>
          <div class="site-nav-links">
            <a href="#section-01-about">Her Tale</a>
            <a href="#section-02-menu">Potion Ledger</a>
            <a href="#section-03-gallery">Gallery</a>
            <a href="#faires">Faires</a>
            <a class="site-nav-accent" href="#contact">Send Word</a>
          </div>
        </div>
      </nav>

      <div class="scroll-rod scroll-rod--top" aria-hidden="true"></div>

      <header class="hero">
        <div class="hero-backdrop" aria-hidden="true"></div>
        <div class="hero-content">
          <div class="seal" aria-hidden="true">{{ site.characterName | first }}</div>
          <p class="eyebrow">{{ site.eyebrow }}</p>
          <h1>{{ site.characterName }}</h1>
          <p class="hero-subhead">{{ site.heroSubhead }}</p>
          <div class="hero-ctas">
            <a class="btn btn-primary" href="{{ site.heroPrimaryCta.href }}">{{ site.heroPrimaryCta.label }}</a>
            <a class="btn btn-outline" href="{{ site.heroSecondaryCta.href }}">{{ site.heroSecondaryCta.label }}</a>
          </div>
        </div>
      </header>

      <main id="main">{{ content | safe }}</main>

      <footer class="footer-band">
        <p>{{ site.footerLine }}</p>
      </footer>

      <div class="scroll-rod scroll-rod--bottom" aria-hidden="true"></div>
    </div>

    <dialog id="lightbox" class="lightbox" aria-label="Gallery image viewer">
      <button type="button" class="lightbox-close" aria-label="Close">&times;</button>
      <button type="button" class="lightbox-prev" aria-label="Previous image">&#10094;</button>
      <img class="lightbox-image" src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==" alt="">
      <button type="button" class="lightbox-next" aria-label="Next image">&#10095;</button>
    </dialog>
    <script src="scripts/lightbox.js" defer></script>
  </body>
</html>
