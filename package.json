{
  "name": "teaks-site",
  "version": "1.0.0",
  "private": true,
  "description": "One-page character site built with Eleventy",
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "eleventy",
    "serve": "eleventy --serve",
    "lint:js": "eslint .",
    "lint:css": "stylelint \"styles/**/*.css\"",
    "lint:md": "markdownlint-cli2 \"content/**/*.md\"",
    "lint": "pnpm run lint:js && pnpm run lint:css && pnpm run lint:md",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "node --test \"test/**/*.test.js\"",
    "test:html": "html-validate \"_site/**/*.html\"",
    "test:links": "linkinator ./_site --recurse --silent --retry --status-code 429:warn",
    "test:a11y": "node test/a11y.check.mjs",
    "test": "pnpm run build && pnpm run test:unit && pnpm run test:html && pnpm run test:a11y && pnpm run test:links",
    "validate": "pnpm run lint && pnpm run test"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-img": "^6.0.4",
    "@eslint/js": "^10.0.1",
    "axe-core": "^4.12.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "html-validate": "^11.5.5",
    "jsdom": "^29.1.1",
    "linkinator": "^7.6.1",
    "markdownlint-cli2": "^0.23.0",
    "prettier": "^3.9.4",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0"
  }
}
